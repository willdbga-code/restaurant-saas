rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      // MASTER KEY BYPASS - Somente Super Admin (Fallback seguro)
      allow read, write: if isSuperAdmin();
    }

    // --------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // --------------------------------------------------------------------------

    function isAuthed() {
      return request.auth != null;
    }

    function myRestaurantId() {
      return !isAuthed() ? null :
             ('restaurant_id' in request.auth.token ? request.auth.token.restaurant_id :
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('restaurant_id', null) : null));
    }


    function myRole() {
      return !isAuthed() ? 'customer' :
             ('role' in request.auth.token ? request.auth.token.role :
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'customer') : 'customer'));
    }


    function isSuperAdmin() {
      return isAuthed() && (
        request.auth.token.email.lower() == 'willdbga@gmail.com' ||
        request.auth.token.email.lower() == 'willdbga@outlook.com'
      );
    }

    function isAdmin() {
      return isAuthed() && (isSuperAdmin() || myRole() == 'admin');
    }

    function isWaiter() {
      return isAuthed() && myRole() == 'waiter';
    }

    function isKitchen() {
      return isAuthed() && myRole() == 'kitchen';
    }

    function isBar() {
      return isAuthed() && myRole() == 'bar';
    }

    function isStaff() {
      // Staff real: membros com roles definidas, ou donos de restaurante que perderam a claim.
      // Clientes anônimos NÃO são staff.
      return isSuperAdmin() || isAdmin() || isWaiter() || isKitchen() || isBar() || isRestaurantOwner(myRestaurantId());
    }

    function isCustomerUser() {
      // Usuário anônimo que se identificou no cardápio (criou doc com role: 'customer')
      return isAuthed() && (
        request.auth.token.get('role', null) == null ||
        request.auth.token.get('role', null) == 'customer'
      );
    }

    function isCustomer() {
      return isAuthed() && (request.auth.token.get('role', null) == null || request.auth.token.role == 'customer');
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthed() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/restaurants/$(restaurantId)) && 
         get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.owner_uid == request.auth.uid)
      );
    }

    function resourceIsMyRestaurant() {
      return isSuperAdmin() || (isAuthed() && (
        resource.data.get('restaurant_id', null) == myRestaurantId() ||
        (isCustomer() && restaurantIsActive(resource.data.get('restaurant_id', 'none')))
      ));
    }

    function incomingIsMyRestaurant() {
      return isSuperAdmin() || (isAuthed() && request.resource.data.get('restaurant_id', null) == myRestaurantId());
    }

    function onlyKitchenFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']);
    }

    function restaurantIsActive(restaurantId) {
      return get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.is_active == true;
    }

    function getPlanTablesLimit(restaurantId) {
      return get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.plan_type == 'free' ? 5 : (get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.plan_type == 'pro' ? 30 : 100);
    }

    function tableBelongsToRestaurant(tableId, restaurantId) {
      return get(/databases/$(database)/documents/tables/$(tableId)).data.restaurant_id == restaurantId;
    }

    // --------------------------------------------------------------------------
    // METADATA
    // --------------------------------------------------------------------------
    match /metadata/{restaurantId} {
      allow read: if isAuthed() && (restaurantId == 'system' || isRestaurantOwner(restaurantId) || (isStaff() && (myRestaurantId() == restaurantId || isSuperAdmin())) || isSuperAdmin());
      allow write: if isAuthed() && (isRestaurantOwner(restaurantId) || isSuperAdmin());

      match /counters/{counterId} {
        allow read, write: if isAuthed(); // Permitir aos clientes gerar numeros de pedido
      }
    }

    // --------------------------------------------------------------------------
    // RESTAURANTS
    // --------------------------------------------------------------------------
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.owner_uid == request.auth.uid;
      allow update: if (isAdmin() || isSuperAdmin()) && (myRestaurantId() == restaurantId || isSuperAdmin());
      allow delete: if isSuperAdmin();

      match /private_settings/{settingId} {
        allow read: if (isAdmin() || isSuperAdmin()) && (myRestaurantId() == restaurantId || isSuperAdmin());
        allow write: if (isAdmin() || isSuperAdmin()) && (myRestaurantId() == restaurantId || isSuperAdmin());
      }
    }

    // --------------------------------------------------------------------------
    // USERS
    // --------------------------------------------------------------------------
    match /users/{userId} {
      allow list: if isStaff();
      allow read: if isAuthed() && (request.auth.uid == userId || (isStaff() && resourceIsMyRestaurant()));
      allow create: if isAuthed() && (request.auth.uid == userId || (isAdmin() && incomingIsMyRestaurant()));
      allow update: if isAuthed() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'restaurant_id'])) || 
        (isAdmin() && resourceIsMyRestaurant() && incomingIsMyRestaurant()) ||
        isSuperAdmin()
      );
      allow delete: if (isAdmin() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
    }

    // --------------------------------------------------------------------------
    // TABLES
    // --------------------------------------------------------------------------
    match /tables/{tableId} {
      allow read: if true;
      allow create: if (isAdmin() || isSuperAdmin()) && (incomingIsMyRestaurant() || isSuperAdmin());

      // Staff completo OU cliente anônimo atualizando apenas campos da "Ponte Invisível"
      allow update: if (isStaff() && (resourceIsMyRestaurant() || isSuperAdmin())) || 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'current_order_id', 'updated_at']);
      allow delete: if (isAdmin() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
    }

    // --- Invitations (Staff Onboarding) ---------------------------------------
    match /invitations/{inviteId} {
      // Qualquer pessoa pode ler o convite (para validar o link)
      allow read: if true;

      // Criação permitida se o usuário está autenticado e pertence ao restaurante
      allow create: if isAuthed() && (
        isAdmin() ||
        isSuperAdmin() ||
        myRestaurantId() == request.resource.data.restaurant_id
      );

      // Atualizar ou deletar só por admin/super-admin ou pelo dono do restaurante
      allow update, delete: if isAuthed() && (
        isAdmin() ||
        isSuperAdmin() ||
        isRestaurantOwner(resource.data.restaurant_id)
      ) && (resourceIsMyRestaurant() || isSuperAdmin());
    }



    // --------------------------------------------------------------------------
    // ALERTS & NOTIFICATIONS
    // --------------------------------------------------------------------------
    match /table_alerts/{alertId} {
      allow create: if isAuthed();
      allow read, update: if isStaff() && (resourceIsMyRestaurant() || isSuperAdmin());
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /notifications/{notifId} {
      allow create: if isAuthed();
      allow read, update: if isStaff() && (resourceIsMyRestaurant() || isSuperAdmin());
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // --------------------------------------------------------------------------
    // MENU
    // --------------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if (isAdmin() || isSuperAdmin()) && (incomingIsMyRestaurant() || isSuperAdmin());
      allow update: if (isAdmin() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
      allow delete: if (isAdmin() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if (isAdmin() || isSuperAdmin()) && (incomingIsMyRestaurant() || isSuperAdmin());
      // Staff pode atualizar tudo; clientes autenticados podem alterar apenas stock (via transação de addOrderItem/cancelamento)
      // mas somente dentro do restaurante ativo onde fizeram o pedido
      allow update: if (isStaff() && (resourceIsMyRestaurant() || isSuperAdmin())) ||
                      (isAuthed() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updated_at']) && restaurantIsActive(resource.data.get('restaurant_id', 'none')));
      allow delete: if (isAdmin() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
    }

    // --------------------------------------------------------------------------
    // ORDERS
    // --------------------------------------------------------------------------
    match /orders/{orderId} {
      allow get: if true;
      allow list: if isAuthed() && (
        (isStaff() && request.query.limit <= 100 && resourceIsMyRestaurant()) ||
        isSuperAdmin() ||
        // Cliente rastreando pedidos da sua mesa — obriga filtro por restaurant_id ativo
        (request.query.limit <= 10 && restaurantIsActive(resource.data.get('restaurant_id', 'none')))
      );
      allow create: if restaurantIsActive(request.resource.data.restaurant_id) && 
                      (request.resource.data.table_id == null || tableBelongsToRestaurant(request.resource.data.table_id, request.resource.data.restaurant_id));
      allow update: if isAuthed() && (
        (isStaff() && resourceIsMyRestaurant()) || 
        isSuperAdmin() ||
        // PONTE INVISÍVEL (restrita): Apenas campos operacionais de transação, e obriga restaurante ativo
        (restaurantIsActive(resource.data.get('restaurant_id', 'none')) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'subtotal', 'total', 'items_count', 'updated_at', 'status', 'confirmed_at',
           'amount_paid', 'payment_status', 'payment_method', 'closed_at'
         ]))
      );
      allow delete: if (isAdmin() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
    }

    match /order_items/{itemId} {
      allow get: if true;
      allow list: if isAuthed() && (
        (isStaff() && resourceIsMyRestaurant()) || 
        isSuperAdmin() || 
        // Cliente rastreando seus itens — obriga filtro por restaurante ativo e limita resultados
        (request.query.limit <= 50 && restaurantIsActive(resource.data.get('restaurant_id', 'none')))
      );
      allow create: if restaurantIsActive(request.resource.data.restaurant_id);
      allow update: if isStaff() && (resourceIsMyRestaurant() || isSuperAdmin()) && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['restaurant_id', 'order_id']);
      allow delete: if (isAdmin() || isWaiter() || isSuperAdmin()) && (resourceIsMyRestaurant() || isSuperAdmin());
    }

    match /order_payments/{paymentId} {
      // Staff pode ver todos os pagamentos do restaurante
      allow get: if isStaff() && (resourceIsMyRestaurant() || isSuperAdmin());
      allow list: if isStaff() && (request.query.limit <= 100 && resourceIsMyRestaurant());
      // Cliente E staff podem criar pagamentos (cliente paga sua própria conta)
      allow create: if restaurantIsActive(request.resource.data.restaurant_id) && 
                      (isStaff() || isCustomerUser()) && (incomingIsMyRestaurant() || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }

    // --------------------------------------------------------------------------
    // SYSTEM
    // --------------------------------------------------------------------------
    match /system_logs/{logId} {
      allow read, write: if isSuperAdmin();
    }
    match /support_tickets/{ticketId} {
      allow read, write: if isSuperAdmin();
    }
    match /support_messages/{messageId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
